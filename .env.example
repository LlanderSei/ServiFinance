# Copy this file to `.env` for local development.
# In production, prefer real host environment variables instead of a deployed .env file.

ConnectionStrings__DefaultConnection=Server=.\SQLEXPRESS;Database=ServiFinance;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;
ServiFinance__DevelopmentTenantId=11111111-1111-1111-1111-111111111111
ServiFinance__DevelopmentAdminEmail=admin@example.com
ServiFinance__DevelopmentAdminPassword=change-me
ServiFinance__SuperAdminEmail=superadmin@example.com
ServiFinance__SuperAdminPassword=change-me
ServiFinance__Auth__Issuer=ServiFinance.Dev
ServiFinance__Auth__Audience=ServiFinance.Clients
ServiFinance__Auth__SigningKey=replace-with-a-long-random-secret
ServiFinance__Auth__AccessTokenMinutes=30
ServiFinance__Auth__RefreshTokenDays=1
ServiFinance__Auth__PersistentRefreshTokenDays=14
ServiFinance__Stripe__SecretKey=your-stripe-secret-key-here
ServiFinance__Stripe__WebhookSecret=your-stripe-webhook-secret-here
ServiFinance__ExternalServices__ImgBB__ApiKey=your-imgbb-api-key-here
ServiFinance__ExternalServices__Nominatim__UserAgent=ServiFinance/1.0 (your-email@example.com)
ServiFinance__ExternalServices__Nominatim__ContactEmail=your-email@example.com
ServiFinance__ExternalServices__Google__ClientId=your-google-client-id-here
ServiFinance__ExternalServices__Google__ClientSecret=your-google-client-secret-here
ServiFinance__ExternalServices__Turnstile__SiteKey=your-cloudflare-turnstile-site-key-here
ServiFinance__ExternalServices__Turnstile__SecretKey=your-cloudflare-turnstile-secret-key-here
ServiFinance__Email__Smtp__Host=smtp-relay.brevo.com
ServiFinance__Email__Smtp__Port=587
ServiFinance__Email__Smtp__Username=your-smtp-login
ServiFinance__Email__Smtp__Password=your-smtp-password-or-api-key
ServiFinance__Email__Smtp__FromEmail=no-reply@example.com
ServiFinance__Email__Smtp__FromName=ServiFinance
ServiFinance__Email__Smtp__EnableSsl=true
