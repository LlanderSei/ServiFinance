{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiFinance": {
    "Auth": {
      "Issuer": "ServiFinance",
      "Audience": "ServiFinance.Clients",
      "AccessTokenMinutes": 30,
      "RefreshTokenDays": 1,
      "PersistentRefreshTokenDays": 14
    }
  }
}
