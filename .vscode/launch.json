{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Web Hot Reload",
      "configurations": [
        "Web Hot Reload API",
        "Frontend Hot Reload (Vite)"
      ],
      "stopAll": true
    },
    {
      "name": "Web + Desktop",
      "configurations": [
        "Web",
        "Desktop (Windows)"
      ]
    }
  ],
  "configurations": [
    {
      "name": "Publish Web (MonsterASP)",
      "type": "pwa-node",
      "request": "launch",
      "preLaunchTask": "publish-web-monsterasp",
      "program": "${workspaceFolder}/scripts/vscode-debug-exit.cjs",
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Publish Web (Folder)",
      "type": "pwa-node",
      "request": "launch",
      "preLaunchTask": "publish-web-folder",
      "program": "${workspaceFolder}/scripts/vscode-debug-exit.cjs",
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Web Hot Reload API",
      "type": "node-terminal",
      "request": "launch",
      "command": "dotnet watch --project \"${workspaceFolder}/src/backend/ServiFinance.Api/ServiFinance.Api.csproj\" run --no-launch-profile -e ASPNETCORE_ENVIRONMENT=Development -e ASPNETCORE_URLS=http://localhost:5228 -p:DisableServiFinanceFrontendBuild=true"
    },
    {
      "name": "Frontend Hot Reload (Vite)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cmd /c npm --prefix \"${workspaceFolder}/src/frontend/ServiFinance.Frontend\" run dev -- --open"
    },
    {
      "name": "Web",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/backend/ServiFinance.Api/ServiFinance.Api.csproj",
      "launchSettingsProfile": "https",
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Web Browser (Edge)",
        "pattern": "\\bNow listening on:\\s+(https://\\S+)"
      }
    },
    {
      "name": "Desktop (Windows)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-desktop",
      "program": "${workspaceFolder}/src/desktop/ServiFinance.Desktop/bin/Debug/net10.0-windows10.0.19041.0/win-x64/ServiFinance.Desktop.exe",
      "cwd": "${workspaceFolder}/src/desktop/ServiFinance.Desktop",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Web Browser (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "https://localhost:7245",
      "webRoot": "${workspaceFolder}",
      "userDataDir": false,
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Web Browser (Vite)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/frontend/ServiFinance.Frontend",
      "userDataDir": false,
      "presentation": {
        "hidden": true
      }
    }
  ]
}
