{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Web + Desktop",
      "configurations": [
        "Web",
        "Desktop (Windows)"
      ]
    }
  ],
  "configurations": [
    {
      "name": "Web",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/src/backend/ServiFinance.Api/ServiFinance.Api.csproj",
      "launchSettingsProfile": "https",
      "serverReadyAction": {
        "action": "startDebugging",
        "name": "Web Browser (Edge)",
        "pattern": "\\bNow listening on:\\s+(https://\\S+)"
      }
    },
    {
      "name": "Desktop (Windows)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-desktop",
      "program": "${workspaceFolder}/src/desktop/ServiFinance.Desktop/bin/Debug/net10.0-windows10.0.19041.0/win-x64/ServiFinance.Desktop.exe",
      "cwd": "${workspaceFolder}/src/desktop/ServiFinance.Desktop",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Web Browser (Edge)",
      "type": "msedge",
      "request": "launch",
      "url": "https://localhost:7245",
      "webRoot": "${workspaceFolder}",
      "userDataDir": false,
      "presentation": {
        "hidden": true
      }
    }
  ]
}
