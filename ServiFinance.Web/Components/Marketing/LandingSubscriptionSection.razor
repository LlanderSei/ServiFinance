@using ServiFinance.Application.Subscriptions

<section id="plans" class="sf-marketing-section sf-marketing-section--plans">
    <div class="sf-public-container">
        <div class="sf-section-heading">
            <p class="sf-marketing-eyebrow">Subscription tiers</p>
            <h2>Choose the surface mix that fits how the business actually operates.</h2>
            <p>Tier cards are driven by seeded platform records so the landing page reflects the current plan catalog instead of hardcoded marketing text.</p>
        </div>

        @if (Tiers.Count == 0)
        {
            <div class="sf-marketing-card sf-empty-state">
                <h3>No tiers are configured yet.</h3>
                <p>Seed the platform catalog to publish subscription options on the landing page.</p>
            </div>
        }
        else
        {
            <div class="sf-tier-grid">
                @foreach (var tier in Tiers)
                {
                    <article class="sf-tier-card @(tier.IncludesMicroLendingDesktop ? "is-featured" : string.Empty)">
                        <div class="sf-tier-topline">
                            <span class="sf-tier-highlight">@tier.HighlightLabel</span>
                            <span class="sf-tier-code">@tier.Code</span>
                        </div>

                        <div class="sf-tier-main">
                            <h3>@tier.DisplayName</h3>
                            <p class="sf-tier-audience">@tier.AudienceSummary</p>
                            <div class="sf-tier-price">@tier.PriceDisplay</div>
                            <div class="sf-tier-billing">@tier.BillingLabel</div>
                            <p class="sf-tier-summary">@tier.PlanSummary</p>
                        </div>

                        <ul class="sf-tier-features">
                            <li class="@(tier.IncludesServiceManagementWeb ? "is-included" : string.Empty)">
                                <i class="bi @(tier.IncludesServiceManagementWeb ? "bi-check-circle-fill" : "bi-dash-circle")"></i>
                                Service Management System on web
                            </li>
                            <li class="@(tier.IncludesMicroLendingDesktop ? "is-included" : string.Empty)">
                                <i class="bi @(tier.IncludesMicroLendingDesktop ? "bi-check-circle-fill" : "bi-dash-circle")"></i>
                                Micro-Lending System on desktop
                            </li>
                            <li class="is-included">
                                <i class="bi bi-check-circle-fill"></i>
                                Shared tenant identity across enabled modules
                            </li>
                        </ul>

                        <p class="sf-tier-description">@tier.Description</p>
                    </article>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter]
    public IReadOnlyList<SubscriptionTierCard> Tiers { get; set; } = [];
}

