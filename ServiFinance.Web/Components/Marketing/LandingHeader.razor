<header class="sf-marketing-header-wrap">
    <div class="sf-public-container">
        <div class="sf-marketing-header">
            <a class="sf-marketing-brand" href="/">
                <span class="sf-marketing-brand-mark"><i class="bi bi-grid-1x2"></i></span>
                <span>
                    <strong>ServiFinance</strong>
                    <small>Platform control plane</small>
                </span>
            </a>

            <nav class="sf-marketing-nav" aria-label="Primary">
                <a href="#platform">Platform</a>
                <a href="#plans">Plans</a>
                <a href="#workflow">How It Works</a>
            </nav>

            <div class="sf-marketing-header-actions">
                <button type="button" class="btn sf-marketing-btn sf-marketing-btn--subtle" @onclick="() => OnLoginRequested.InvokeAsync()">Login</button>
                <a class="btn sf-marketing-btn sf-marketing-btn--solid" href="/register">Register</a>
            </div>
        </div>
    </div>
</header>

@code {
    [Parameter]
    public EventCallback OnLoginRequested { get; set; }
}
