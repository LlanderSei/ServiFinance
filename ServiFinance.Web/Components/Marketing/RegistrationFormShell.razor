@using ServiFinance.Application.Subscriptions

<section class="sf-register-form-panel">
    <div class="sf-register-panel-head">
        <p class="sf-marketing-eyebrow">Registration shell</p>
        <h2>Business and owner setup</h2>
        <p>All fields are currently non-functional except the plan selector used to preview the selected subscription tier.</p>
    </div>

    <div class="sf-register-form-grid">
        <section class="sf-register-field-group">
            <header>
                <span class="sf-register-group-mark"><i class="bi bi-buildings"></i></span>
                <div>
                    <h3>Business</h3>
                    <p>Tenant identity and route ownership.</p>
                </div>
            </header>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Business name</label>
                    <input class="form-control sf-input" placeholder="Example Domain Services" disabled />
                </div>
                <div class="col-12">
                    <label class="form-label">Tenant domain slug</label>
                    <input class="form-control sf-input" placeholder="exampledomain" disabled />
                </div>
            </div>
        </section>

        <section class="sf-register-field-group">
            <header>
                <span class="sf-register-group-mark"><i class="bi bi-person-badge"></i></span>
                <div>
                    <h3>Owner</h3>
                    <p>Initial administrator details for the tenant.</p>
                </div>
            </header>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Owner full name</label>
                    <input class="form-control sf-input" placeholder="Jane Doe" disabled />
                </div>
                <div class="col-12">
                    <label class="form-label">Owner email</label>
                    <input class="form-control sf-input" placeholder="owner@example.com" disabled />
                </div>
            </div>
        </section>

        <section class="sf-register-field-group">
            <header>
                <span class="sf-register-group-mark"><i class="bi bi-stars"></i></span>
                <div>
                    <h3>Plan</h3>
                    <p>Preview the operating surface mix before onboarding is enabled.</p>
                </div>
            </header>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label">Subscription tier</label>
                    <select
                        class="form-select sf-input"
                        value="@SelectedTierCode"
                        @onchange="OnChange"
                        disabled="@(!Tiers.Any())">
                        @if (!Tiers.Any())
                        {
                            <option value="">No active tiers available</option>
                        }
                        else
                        {
                            @foreach (var tier in Tiers)
                            {
                                <option value="@tier.Code">@tier.DisplayName</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </section>
    </div>

    <div class="sf-register-status">
        <div class="sf-register-status-copy">
            <strong>Future onboarding only</strong>
            <span>Persistence, billing, and tenant activation are intentionally not implemented in this phase.</span>
        </div>
        <button type="button" class="btn sf-marketing-btn sf-marketing-btn--solid" disabled>Registration Coming Soon</button>
    </div>
</section>

@code {
    [Parameter]
    public IReadOnlyList<SubscriptionTierCard> Tiers { get; set; } = [];

    [Parameter]
    public string? SelectedTierCode { get; set; }

    [Parameter]
    public EventCallback<string?> OnSelectedTierChanged { get; set; }

    private Task OnChange(ChangeEventArgs args) => OnSelectedTierChanged.InvokeAsync(args.Value?.ToString());
}

