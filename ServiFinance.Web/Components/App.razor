<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (() => {
            try {
                const theme = localStorage.getItem('servifinance-theme');
                if (theme) {
                    document.documentElement.setAttribute('data-theme', theme);
                }
            } catch {
            }
        })();
    </script>
    <link rel="stylesheet" href="_content/ServiFinance.Shared/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="_content/ServiFinance.Shared/app.css" />
    <link rel="stylesheet" href="css/tailwind.css" />
    <link rel="stylesheet" href="css/app-shell.css" />
    <link rel="stylesheet" href="ServiFinance.Web.styles.css" />
    <link rel="icon" type="image/png" href="_content/ServiFinance.Shared/favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <CascadingAuthenticationState>
        <ServiFinance.Web.Components.Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    <script src="js/app-shell.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
