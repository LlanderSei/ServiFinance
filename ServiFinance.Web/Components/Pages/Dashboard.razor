@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Dashboard</PageTitle>

<h1>Operations dashboard</h1>

<p class="lead">You are signed into the tenant-scoped ServiFinance workspace.</p>

<div class="row g-3 mt-1">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-uppercase small text-muted mb-2">Identity</p>
                <div class="fw-semibold">@displayName</div>
                <div class="text-secondary">@email</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-uppercase small text-muted mb-2">Role Set</p>
                <div class="fw-semibold">@roles</div>
                <div class="text-secondary">Roles are loaded from the tenant-scoped user management layer.</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-uppercase small text-muted mb-2">Next Build Area</p>
                <div class="fw-semibold">Service intake and request tracking</div>
                <div class="text-secondary">Authentication and user administration are now available as the platform base.</div>
            </div>
        </div>
    </div>
</div>

@code {
    private string displayName = string.Empty;
    private string email = string.Empty;
    private string roles = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        displayName = user.Identity?.Name ?? "Unknown user";
        email = user.FindFirst(ClaimTypes.Email)?.Value ?? "No email";
        roles = string.Join(", ", user.FindAll(ClaimTypes.Role).Select(claim => claim.Value));
    }
}
