@page "/"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@rendermode InteractiveServer
@layout PublicLayout

@using ServiFinance.Infrastructure.Subscriptions
@using ServiFinance.Web.Components.Marketing
@inject ISubscriptionTierCatalogService SubscriptionTierCatalogService

<PageTitle>ServiFinance</PageTitle>

<div class="sf-marketing-page">
    <LandingHeader OnLoginRequested="OpenLoginModal" />

    <main>
        <LandingHeroSection OnPrimaryAction="OpenLoginModal" />
        <LandingOverviewSection />
        <LandingSubscriptionSection Tiers="_tiers" />
        <LandingWorkflowSection />
    </main>

    <LandingFooter />
</div>

<RootLoginModal
    Visible="_showLogin"
    Error="@Error"
    ReturnUrl="@ResolvedReturnUrl"
    OnClose="CloseModal" />

@if (false && showLogin)
{
    <div class="modal fade show d-block sf-modal-backdrop" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content sf-modal-content">
                <div class="modal-header sf-modal-header">
                    <h2 class="modal-title fs-5">SuperAdmin Login</h2>
                    <button type="button" class="sf-modal-close" aria-label="Close" @onclick="CloseModal">×</button>
                </div>
                <form method="post" action="/account/root-login">
                    <AntiforgeryToken />
                    <div class="modal-body sf-modal-body">
                        @if (!string.IsNullOrWhiteSpace(Error))
                        {
                            <div class="alert alert-danger" role="alert">@Error</div>
                        }

                        <input type="hidden" name="ReturnUrl" value="@ResolvedReturnUrl" />

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input name="Email" class="form-control sf-input" autocomplete="username" value="superadmin@local.servifinance" />
                        </div>

                        <div class="mb-0">
                            <label class="form-label">Password</label>
                            <input name="Password" type="password" class="form-control sf-input" autocomplete="current-password" />
                        </div>
                    </div>
                    <div class="modal-footer sf-modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Sign In</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "showLogin")]
    public bool? ShowLogin { get; set; }

    private IReadOnlyList<SubscriptionTierCard> _tiers = [];
    private bool showLogin;
    private bool _showLogin;
    private string ResolvedReturnUrl => string.IsNullOrWhiteSpace(ReturnUrl) ? "/dashboard" : ReturnUrl!;

    protected override async Task OnInitializedAsync()
    {
        _tiers = await SubscriptionTierCatalogService.GetActiveTiersAsync();
    }

    protected override void OnParametersSet()
    {
        showLogin = false;
        _showLogin = ShowLogin == true || !string.IsNullOrWhiteSpace(Error);
    }

    private void OpenLoginModal()
    {
        _showLogin = true;
    }

    private void CloseModal()
    {
        showLogin = false;
        _showLogin = false;
        Error = null;
    }
}
