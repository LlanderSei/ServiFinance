@page "/{TenantDomainSlug}/mls/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>MLS Dashboard</PageTitle>

<ServiFinance.Web.Components.Auth.AuthenticatedRouteView TenantDomainSlug="@TenantDomainSlug">
    <PageChrome Title="MLS Dashboard"
                Breadcrumbs="breadcrumbs"
                Badges="badges" />

    <h1>Micro-Lending System</h1>
    <p class="text-secondary">Tenant-specific desktop placeholder surface for <strong>@TenantDomainSlug</strong>.</p>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <p class="text-uppercase small text-muted mb-2">Current scope</p>
            <div class="fw-semibold">Desktop placeholder only</div>
            <div class="text-secondary">This route documents the tenant-aware desktop entry point until the MAUI client is wired to shared auth.</div>
        </div>
    </div>
</ServiFinance.Web.Components.Auth.AuthenticatedRouteView>

@code {
    [Parameter]
    public string TenantDomainSlug { get; set; } = string.Empty;

    private IReadOnlyList<BreadcrumbItem> breadcrumbs => [
        new(ToDisplayName(TenantDomainSlug)),
        new("MLS"),
        new("Dashboard")
    ];

    private readonly IReadOnlyList<HeaderBadge> badges = [
        new("Module", "MLS")
    ];

    private static string ToDisplayName(string slug) =>
        string.IsNullOrWhiteSpace(slug) ? "Tenant" : char.ToUpperInvariant(slug[0]) + slug[1..];
}
