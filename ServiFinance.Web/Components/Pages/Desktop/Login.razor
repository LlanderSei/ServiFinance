@page "/{TenantDomainSlug}/mls/"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@rendermode InteractiveServer
@layout PublicLayout

<PageTitle>Micro-Lending System</PageTitle>

<div class="sf-public-container py-5">
    <section class="sf-surface-card sf-hero">
        <p class="sf-kicker mb-2">@TenantDomainSlug / MLS</p>
        <h1 class="display-6 mb-3">Micro-Lending System</h1>
        <p class="lead sf-muted mb-4">Public landing page for the tenant-scoped Micro-Lending System of <strong>@TenantDomainSlug</strong>.</p>
        <button class="btn btn-primary" @onclick="() => showLogin = true">Login</button>
    </section>
</div>

@if (showLogin)
{
    <div class="modal fade show d-block sf-modal-backdrop" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content sf-modal-content">
                <div class="modal-header sf-modal-header">
                    <h2 class="modal-title fs-5">MLS Login</h2>
                    <button type="button" class="sf-modal-close" aria-label="Close" @onclick="CloseModal">×</button>
                </div>
                <form method="post" action="/account/tenant-login">
                    <AntiforgeryToken />
                    <div class="modal-body sf-modal-body">
                        @if (!string.IsNullOrWhiteSpace(Error))
                        {
                            <div class="alert alert-danger" role="alert">@Error</div>
                        }

                        <input type="hidden" name="TenantDomainSlug" value="@TenantDomainSlug" />
                        <input type="hidden" name="TargetSystem" value="mls" />
                        <input type="hidden" name="ReturnUrl" value="@ResolvedReturnUrl" />

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input name="Email" class="form-control sf-input" autocomplete="username" value="admin@local.servifinance" />
                        </div>

                        <div class="mb-0">
                            <label class="form-label">Password</label>
                            <input name="Password" type="password" class="form-control sf-input" autocomplete="current-password" />
                        </div>
                    </div>
                    <div class="modal-footer sf-modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Sign In</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string TenantDomainSlug { get; set; } = string.Empty;

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "showLogin")]
    public bool? ShowLogin { get; set; }

    private bool showLogin;
    private string ResolvedReturnUrl => string.IsNullOrWhiteSpace(ReturnUrl) ? $"/{TenantDomainSlug}/mls/dashboard" : ReturnUrl!;

    protected override void OnParametersSet()
    {
        showLogin = ShowLogin == true || !string.IsNullOrWhiteSpace(Error);
    }

    private void CloseModal()
    {
        showLogin = false;
        Error = null;
    }
}
