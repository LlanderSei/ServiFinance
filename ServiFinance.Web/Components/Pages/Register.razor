@page "/register"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@rendermode InteractiveServer
@layout PublicLayout
@using ServiFinance.Infrastructure.Subscriptions
@using ServiFinance.Web.Components.Marketing
@inject ISubscriptionTierCatalogService SubscriptionTierCatalogService
@inject NavigationManager NavigationManager

<PageTitle>Register</PageTitle>

<div class="sf-register-page">
    <LandingHeader OnLoginRequested="HandleLoginRequest" />

    <main class="sf-register-main">
        <div class="sf-public-container">
            <div class="sf-register-shell">
                <RegistrationContextPanel />

                <div class="sf-register-workspace">
                    <RegistrationFormShell
                        Tiers="_tiers"
                        SelectedTierCode="@_selectedTierCode"
                        OnSelectedTierChanged="HandleTierChanged" />

                    <RegistrationTierSummary Tier="@SelectedTier" HasAvailableTiers="@_tiers.Any()" />
                </div>
            </div>
        </div>
    </main>

    <LandingFooter />
</div>

@code {
    private IReadOnlyList<SubscriptionTierCard> _tiers = [];
    private string? _selectedTierCode;

    private SubscriptionTierCard? SelectedTier =>
        _tiers.FirstOrDefault(entity => string.Equals(entity.Code, _selectedTierCode, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _tiers = await SubscriptionTierCatalogService.GetActiveTiersAsync();
        _selectedTierCode = _tiers.FirstOrDefault()?.Code;
    }

    private void HandleTierChanged(string? code)
    {
        _selectedTierCode = code;
    }

    private void HandleLoginRequest()
    {
        NavigationManager.NavigateTo("/?showLogin=true&returnUrl=%2Fregister", forceLoad: true);
    }
}
