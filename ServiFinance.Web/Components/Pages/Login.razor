@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout MainLayout
@using System.Security.Claims
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Sign In</PageTitle>

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-5">
    <section class="card shadow-sm border-0">
      <div class="card-body p-4">
        <p class="text-uppercase small text-muted mb-2">ServiFinance Access</p>
        <h1 class="h3 mb-3">Sign in</h1>
        <p class="text-secondary mb-4">Use the tenant-scoped account seeded for development or a user created from the
          admin page.</p>

          @if (!string.IsNullOrWhiteSpace(Error))
          {
            <div class="alert alert-danger" role="alert">@Error</div>
          }

          <form method="post" action="/account/login">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

            <div class="mb-3">
              <label class="form-label" for="email">Email</label>
              <input id="email" name="Email" class="form-control" value="@(CurrentEmail ?? "admin@local.servifinance")"
                     autocomplete="username" />
            </div>

            <div class="mb-4">
              <label class="form-label" for="password">Password</label>
              <input id="password" name="Password" type="password" class="form-control" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Sign In</button>
          </form>

          <div class="mt-4 rounded bg-light p-3 small text-secondary">
            <div><strong>Default dev login</strong></div>
            <div>Email: <code>admin@local.servifinance</code></div>
            <div>Password: <code>Admin123!</code></div>
          </div>
        </div>
      </section>
    </div>
  </div>

@code {
  [SupplyParameterFromQuery(Name = "error")]
  public string? Error { get; set; }

  [SupplyParameterFromQuery(Name = "returnUrl")]
  public string? ReturnUrl { get; set; }

  private string? CurrentEmail { get; set; }

  protected override void OnInitialized()
  {
    if (HttpContextAccessor.HttpContext?.User.Identity?.IsAuthenticated == true)
    {
      CurrentEmail = HttpContextAccessor.HttpContext.User.FindFirstValue(ClaimTypes.Email);
    }

    ReturnUrl = string.IsNullOrWhiteSpace(ReturnUrl) ? "/dashboard" : ReturnUrl;
  }
}
