@page "/dashboard"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]

<PageTitle>SaaS Dashboard</PageTitle>

<ServiFinance.Web.Components.Auth.AuthenticatedRouteView RequireRootSuperAdmin="true">
    <PageChrome Title="SaaS Dashboard"
                Breadcrumbs="breadcrumbs"
                Badges="badges" />

    <h1>SaaS Dashboard</h1>

    <p class="lead">Root-domain superadmin surface for platform operations, tenant oversight, and subscription management.</p>

    <div class="row g-3 mt-1">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <p class="text-uppercase small text-muted mb-2">Platform Scope</p>
                    <div class="fw-semibold">Root-domain control plane</div>
                    <div class="text-secondary">This surface is reserved for `SuperAdmin` and never crosses into tenant dashboards.</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <p class="text-uppercase small text-muted mb-2">Tenants</p>
                    <div class="fw-semibold">Subscribed tenants</div>
                    <div class="text-secondary">Inspect tenant accounts, future billing posture, and SaaS adoption from one place.</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <p class="text-uppercase small text-muted mb-2">Modules</p>
                    <div class="fw-semibold">Service Management + Micro-Lending</div>
                    <div class="text-secondary">Tenant-scoped product surfaces live outside the root domain and authenticate separately.</div>
                </div>
            </div>
        </div>
    </div>
</ServiFinance.Web.Components.Auth.AuthenticatedRouteView>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> breadcrumbs = [
        new("SaaS"),
        new("Dashboard")
    ];

    private readonly IReadOnlyList<HeaderBadge> badges = [
        new("Scope", "Platform")
    ];
}
