@page "/subscriptions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]

<PageTitle>Subscriptions</PageTitle>

<ServiFinance.Web.Components.Auth.AuthenticatedRouteView RequireRootSuperAdmin="true">
    <PageChrome Title="Subscriptions"
                Breadcrumbs="breadcrumbs" />

    <h1>Subscriptions</h1>
    <p class="text-secondary">Placeholder for SaaS plan management, billing state, and tenant subscription lifecycle.</p>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <p class="text-uppercase small text-muted mb-2">Current scope</p>
            <div class="fw-semibold">Dashboard shell only</div>
            <div class="text-secondary">Billing workflows, payment collection, and tier enforcement are future implementations.</div>
        </div>
    </div>
</ServiFinance.Web.Components.Auth.AuthenticatedRouteView>

@code {
    private readonly IReadOnlyList<BreadcrumbItem> breadcrumbs = [
        new("SaaS"),
        new("Subscriptions")
    ];
}
