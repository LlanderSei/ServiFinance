@inject NavigationManager NavigationManager

@code {
    protected override void OnInitialized()
    {
        var relativePath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relativePath) ? "/" : $"/{relativePath}";
        var tenantSegments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (tenantSegments.Length >= 2)
        {
            if (string.Equals(tenantSegments[1], "sms", StringComparison.OrdinalIgnoreCase))
            {
                NavigationManager.NavigateTo($"/{tenantSegments[0]}/sms/?returnUrl={Uri.EscapeDataString(returnUrl)}&showLogin=true", forceLoad: true);
                return;
            }

            if (string.Equals(tenantSegments[1], "mls", StringComparison.OrdinalIgnoreCase))
            {
                NavigationManager.NavigateTo($"/{tenantSegments[0]}/mls/?returnUrl={Uri.EscapeDataString(returnUrl)}&showLogin=true", forceLoad: true);
                return;
            }
        }

        if (tenantSegments.Length >= 1 && (
            string.Equals(tenantSegments[0], "dashboard", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(tenantSegments[0], "tenants", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(tenantSegments[0], "subscriptions", StringComparison.OrdinalIgnoreCase)))
        {
            NavigationManager.NavigateTo($"/?returnUrl={Uri.EscapeDataString(returnUrl)}&showLogin=true", forceLoad: true);
            return;
        }

        NavigationManager.NavigateTo($"/?returnUrl={Uri.EscapeDataString(returnUrl)}&showLogin=true", forceLoad: true);
    }
}
