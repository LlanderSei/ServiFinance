@if (!string.IsNullOrWhiteSpace(Title) || Breadcrumbs.Count > 0 || Badges.Count > 0)
{
    <header class="sf-header">
        <div class="sf-header__left">
            @if (Breadcrumbs.Count > 0)
            {
                <nav aria-label="Breadcrumb">
                    <ol class="sf-breadcrumbs">
                        @for (var i = 0; i < Breadcrumbs.Count; i++)
                        {
                            var item = Breadcrumbs[i];
                            <li>
                                @if (!string.IsNullOrWhiteSpace(item.Href) && i < Breadcrumbs.Count - 1)
                                {
                                    <a href="@item.Href">@item.Label</a>
                                }
                                else
                                {
                                    <span>@item.Label</span>
                                }
                            </li>
                        }
                    </ol>
                </nav>
            }

            @if (!string.IsNullOrWhiteSpace(Title))
            {
                <div class="sf-header__title">@Title</div>
            }
        </div>

        @if (Badges.Count > 0)
        {
            <div class="sf-header__badges">
                @foreach (var badge in Badges)
                {
                    <span class="sf-header__badge">@badge.Label: @badge.Value</span>
                }
            </div>
        }
    </header>
}

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<BreadcrumbItem> Breadcrumbs { get; set; } = [];
    [Parameter] public IReadOnlyList<HeaderBadge> Badges { get; set; } = [];
}
