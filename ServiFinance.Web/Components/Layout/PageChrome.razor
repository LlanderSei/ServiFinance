@implements IDisposable
@inject PageChromeState ChromeState

@code {
  private readonly Guid token = Guid.NewGuid();

  [Parameter]
  public string Title { get; set; } = string.Empty;

  [Parameter]
  public IReadOnlyList<BreadcrumbItem>? Breadcrumbs { get; set; }

  [Parameter]
  public IReadOnlyList<HeaderBadge>? Badges { get; set; }

  protected override void OnParametersSet()
  {
    ChromeState.Update(token, Title, Breadcrumbs, Badges);
  }

  protected override bool ShouldRender() => false;

  public void Dispose()
  {
    ChromeState.Clear(token);
  }
}
