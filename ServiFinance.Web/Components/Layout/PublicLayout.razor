@inherits LayoutComponentBase

<div class="sf-public-shell">
    <main class="sf-public-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <button type="button" class="reload" onclick="location.reload()">Reload</button>
    <button type="button" class="dismiss" onclick="this.parentElement.style.display='none'">x</button>
</div>
