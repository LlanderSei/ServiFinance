<aside class="sf-sidebar @(IsCollapsed ? "is-collapsed" : string.Empty)">
    <div class="sf-sidebar__panel">
        <div class="sf-sidebar__brand-band">
            <div class="sf-sidebar__mark">@BrandInitials</div>
            @if (!IsCollapsed)
            {
                <div class="sf-sidebar__brand-copy">
                    <div class="sf-sidebar__brand-name">@BrandName</div>
                </div>
            }
        </div>

        <div class="sf-sidebar__user-band">
            <div class="sf-sidebar__user-avatar">@UserInitials</div>
            @if (!IsCollapsed)
            {
                <div class="sf-sidebar__user-copy">
                    <div class="sf-sidebar__user-name">@UserDisplayName</div>
                    @if (!string.IsNullOrWhiteSpace(UserEmail))
                    {
                        <div class="sf-sidebar__user-email">@UserEmail</div>
                    }
                </div>
            }
        </div>

        <div class="sf-sidebar__scroll">
            <nav class="sf-sidebar__nav">
                @foreach (var group in Sections)
                {
                    <div class="sf-sidebar__group">
                        @if (!IsCollapsed && !string.IsNullOrWhiteSpace(group.Title))
                        {
                            <div class="sf-sidebar__group-title">@group.Title</div>
                        }

                        <div class="sf-sidebar__group-items">
                            @foreach (var item in group.Items)
                            {
                                <NavLink class="sf-sidebar__link" href="@item.Href" Match="NavLinkMatch.Prefix">
                                    <span class="@GetIconClass(item.Icon)" aria-hidden="true"></span>
                                    @if (!IsCollapsed)
                                    {
                                        <span class="sf-sidebar__label">@item.Label</span>
                                    }
                                </NavLink>
                            }
                        </div>
                    </div>
                }
            </nav>
        </div>

        <div class="sf-sidebar__footer">
            <div class="sf-sidebar__utility">
                <ThemeToggle Compact="@IsCollapsed" />
            </div>

            <form method="post" action="/account/logout" class="sf-sidebar__logout-form">
                <AntiforgeryToken />
                <input type="hidden" name="returnUrl" value="@LogoutReturnUrl" />
                <button type="submit" class="sf-sidebar__logout">
                    <span class="@GetIconClass("logout")" aria-hidden="true"></span>
                    @if (!IsCollapsed)
                    {
                        <span class="sf-sidebar__label">Logout</span>
                    }
                </button>
            </form>
        </div>

        <button type="button"
                class="sf-sidebar__toggle"
                title="Toggle sidebar"
                @onclick="OnToggleRequested">
            <span class="bi @(IsCollapsed ? "bi-chevron-right" : "bi-chevron-left")" aria-hidden="true"></span>
        </button>
    </div>
</aside>

@code {
    [Parameter] public string BrandName { get; set; } = "ServiFinance";
    [Parameter] public string UserDisplayName { get; set; } = string.Empty;
    [Parameter] public string UserEmail { get; set; } = string.Empty;
    [Parameter] public string LogoutReturnUrl { get; set; } = "/";
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback OnToggleRequested { get; set; }
    [Parameter] public IReadOnlyList<SidebarSection> Sections { get; set; } = [];

    private string BrandInitials => string.Concat(
        BrandName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => char.ToUpperInvariant(part[0]))
            .Take(2));

    private string UserInitials => string.Concat(
        (UserDisplayName ?? string.Empty)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(part => char.ToUpperInvariant(part[0]))
            .Take(2));

    private static string GetIconClass(string icon) => icon switch
    {
        "dashboard" => "bi bi-house-door-fill",
        "tenants" => "bi bi-people-fill",
        "subscriptions" => "bi bi-list-nested",
        "users" => "bi bi-people-fill",
        "logout" => "bi bi-box-arrow-right",
        _ => "bi bi-dot"
    };
}
