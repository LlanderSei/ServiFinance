<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">ServiFinance</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView Context="authState">
            <Authorized>
                <AuthorizeView Roles="SuperAdmin" Context="superAdminState">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/superadmin/dashboard">
                            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> SaaS Dashboard
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/superadmin/tenants">
                            <span class="bi bi-people-nav-menu" aria-hidden="true"></span> Tenants
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/superadmin/subscriptions">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Subscriptions
                        </NavLink>
                    </div>
                </AuthorizeView>

                <AuthorizeView Roles="Administrator" Context="adminState">
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"/{GetTenantSlug(adminState.User)}/dashboard")">
                            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Service Dashboard
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"/{GetTenantSlug(adminState.User)}/admin/users")">
                            <span class="bi bi-people-nav-menu" aria-hidden="true"></span> Tenant Users
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@($"/desktop/{GetTenantSlug(adminState.User)}/dashboard")">
                            <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Desktop Surface
                        </NavLink>
                    </div>
                </AuthorizeView>

                <div class="nav-item px-3">
                    <form method="post" action="/account/logout">
                        <AntiforgeryToken />
                        <input type="hidden" name="returnUrl" value="/" />
                        <button type="submit" class="nav-link nav-button">
                            <span class="bi bi-lock-nav-menu" aria-hidden="true"></span> Sign Out
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/">
                        <span class="bi bi-lock-nav-menu" aria-hidden="true"></span> Sign In
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/register">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private static string GetTenantSlug(ClaimsPrincipal user)
    {
        return user.FindFirst("tenant_domain_slug")?.Value ?? "exampledomain";
    }
}

